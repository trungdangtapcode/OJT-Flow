# Supported values: postgres, sqlite, or memory.
OJT_STORAGE_BACKEND=postgres
OJT_DATABASE_URL=postgresql://ojtflow:ojtflow@localhost:5432/ojtflow
OJT_DATA_DIR=var
OJT_KNOWLEDGE_DIR=knowledge
OJT_MIGRATIONS_DIR=sql/postgres/migrations
OJT_RUNTIME_SETTINGS_PATH=var/runtime_settings.json
OJT_REDIS_URL=redis://localhost:6379/0
OJT_POSTGRES_DB=ojtflow
OJT_POSTGRES_USER=ojtflow
OJT_POSTGRES_PASSWORD=ojtflow
OJT_POSTGRES_PORT=5432
OJT_REDIS_PORT=6379
OJT_API_PORT=8000
OJT_FRONTEND_PORT=5173
VITE_API_BASE_URL=/api/v1
# Use parsing,embeddings-local,rag-framework when building Docker image with
# local HF models/rerankers and the optional LlamaIndex retrieval adapter.
OJT_PYTHON_EXTRAS=parsing
OJT_GOOGLE_CLIENT_ID=
OJT_GOOGLE_CLIENT_SECRET=
OJT_GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
OJT_GOOGLE_FRONTEND_REDIRECT_URI=http://localhost:5173/auth/callback
# Extra OAuth redirect URIs must be HTTPS unless they are localhost/127.0.0.1/[::1].
OJT_ALLOWED_AUTH_REDIRECT_URIS=
# Workspace and cookie domains must be bare DNS domains, not URLs, ports, or wildcards.
OJT_ALLOWED_GOOGLE_HOSTED_DOMAINS=
# Numeric timeout, TTL, byte-limit, and chunk-size values must be positive.
OJT_GOOGLE_OAUTH_TIMEOUT_SECONDS=10.0
OJT_AUTH_SESSION_TTL_SECONDS=604800
OJT_AUTH_STATE_TTL_SECONDS=600
OJT_AUTH_COOKIE_NAME=ojtflow_session
OJT_AUTH_COOKIE_SECURE=false
OJT_AUTH_COOKIE_SAMESITE=lax
# Leave blank for localhost/dev. Set a bare DNS domain such as .example.com in production.
OJT_AUTH_COOKIE_DOMAIN=
OJT_MAX_UPLOAD_BYTES=26214400
OJT_MAX_INLINE_DATA_BYTES=1048576
OJT_UPLOAD_READ_CHUNK_BYTES=1048576
# Supported upload extensions only; unsafe values such as .exe are rejected.
OJT_ALLOWED_UPLOAD_EXTENSIONS=.pdf,.docx,.xlsx,.xls,.pptx,.png,.jpg,.jpeg,.tiff,.tif,.bmp,.gif,.webp,.html,.htm,.md,.txt,.csv,.json,.yaml,.yml
# Embeddings. Keep deterministic for offline tests; use OpenAI for real semantic retrieval.
OJT_EMBEDDING_PROVIDER=deterministic
OJT_EMBEDDING_MODEL=deterministic-hash-v0
OJT_EMBEDDING_DIMENSIONS=64
# OpenAI semantic retrieval option:
# OJT_EMBEDDING_PROVIDER=openai
# OJT_EMBEDDING_MODEL=text-embedding-3-small
# OJT_EMBEDDING_DIMENSIONS=384
# OJT_OPENAI_API_KEY=
# Local GPU semantic retrieval option:
# OJT_EMBEDDING_PROVIDER=huggingface
# OJT_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# OJT_EMBEDDING_DIMENSIONS=384
# OJT_HF_EMBEDDING_DEVICE=cuda
OJT_OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1
OJT_OPENAI_EMBEDDING_TIMEOUT_SECONDS=20.0
# Natural-language assistant. Disabled keeps local/dev runs token-free.
OJT_LLM_PROVIDER=disabled
# OJT_LLM_PROVIDER=openai
OJT_LLM_MODEL=chat-latest
OJT_LLM_PLANNING_MODEL=chat-latest
OJT_LLM_SYNTHESIS_MODEL=chat-latest
OJT_LLM_VISION_MODEL=gpt-4.1-mini
OJT_LLM_BASE_URL=https://api.openai.com/v1
OJT_LLM_TIMEOUT_SECONDS=30.0
OJT_LLM_MAX_TOOL_CALLS=4
OJT_LLM_PLANNING_PROGRESS_INTERVAL_SECONDS=2.0
# Enables MarkItDown OCR plugin for scanned PDFs and image-heavy Office files
# when an OpenAI-compatible key is configured.
OJT_MARKITDOWN_OCR_ENABLED=true
# Legacy alias: OJT_OPENAI_VISION_MODEL is still accepted, but new configs
# should use OJT_LLM_VISION_MODEL.
# OJT_OPENAI_VISION_MODEL=gpt-4.1-mini
OJT_HF_EMBEDDING_DEVICE=auto
OJT_HF_EMBEDDING_BATCH_SIZE=32
OJT_HF_EMBEDDING_CACHE_DIR=var/huggingface
# Optional second-stage CrossEncoder reranking for top retrieval candidates.
OJT_RERANK_PROVIDER=none
# OJT_RERANK_PROVIDER=huggingface
OJT_RERANK_MODEL=BAAI/bge-reranker-base
OJT_RERANK_DEVICE=auto
OJT_RERANK_BATCH_SIZE=16
OJT_RERANK_CANDIDATE_LIMIT=20
OJT_RERANK_SCORE_WEIGHT=0.08
OJT_RETRIEVAL_CORPUS_DIRS=knowledge/corpus
OJT_RETRIEVAL_CHUNK_MAX_CHARS=1200
OJT_RETRIEVAL_CHUNK_OVERLAP_CHARS=160
OJT_RETRIEVAL_DIVERSITY_ENABLED=true
OJT_RETRIEVAL_DIVERSITY_LAMBDA=0.72
# Postgres pgvector HNSW recall/speed tradeoff. Higher improves recall and costs latency.
OJT_RETRIEVAL_HNSW_EF_SEARCH=100
# Supported values: custom, llamaindex. Custom keeps the Postgres/static native
# adapter. LlamaIndex uses framework Documents/Nodes/VectorStoreIndex and BM25
# fusion when the rag-framework extra is installed.
OJT_RETRIEVAL_FRAMEWORK=custom
OJT_RETRIEVAL_CANDIDATE_MULTIPLIER=4
OJT_RETRIEVAL_MIN_CANDIDATES=12
OJT_RETRIEVAL_VECTOR_WEIGHT=0.62
OJT_RETRIEVAL_BM25_WEIGHT=0.38
