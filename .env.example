# Supported runtime values: postgres. The memory backend is reserved for in-process tests.
OJT_STORAGE_BACKEND=postgres
OJT_DATABASE_URL=postgresql://ojtflow:ojtflow@localhost:15432/ojtflow
OJT_DATA_DIR=var
# Raw uploaded files and generated dataset bytes. Postgres stores metadata;
# MinIO stores object bytes in the Docker production stack.
OJT_OBJECT_STORAGE_BACKEND=minio
OJT_MINIO_ENDPOINT=localhost:19000
OJT_MINIO_ACCESS_KEY=ojtflow
OJT_MINIO_SECRET_KEY=ojtflow-minio-secret
OJT_MINIO_BUCKET=ojtflow-artifacts
OJT_MINIO_REGION=us-east-1
OJT_MINIO_SECURE=false
OJT_MINIO_API_PORT=19000
OJT_MINIO_CONSOLE_PORT=19001
OJT_KNOWLEDGE_DIR=knowledge
OJT_MIGRATIONS_DIR=sql/postgres/migrations
OJT_RUNTIME_SETTINGS_PATH=var/runtime_settings.json
OJT_REDIS_URL=redis://localhost:16379/0
# Audit records always include hash-chain fields. This flag marks the deployment
# as requiring chained audit records; pilot/production modes require it
# effectively even when this is false.
OJT_AUDIT_HASH_CHAIN_REQUIRED=false
# API rate limiting. Backend values: auto, redis, memory.
OJT_RATE_LIMIT_ENABLED=true
OJT_RATE_LIMIT_BACKEND=auto
OJT_RATE_LIMIT_POLICY_PATH=knowledge/security/rate_limit_policy.json
OJT_RATE_LIMIT_REDIS_PREFIX=ojtflow:rate_limit
OJT_ABUSE_COST_POLICY_PATH=knowledge/security/abuse_cost_policy.json
OJT_AI_RISK_REGISTER_PATH=knowledge/governance/ai_risk_register.json
OJT_OWASP_LLM_THREAT_MODEL_PATH=knowledge/security/owasp_llm_threat_model.json
OJT_DISCLAIMER_POLICY_PATH=knowledge/governance/disclaimer_policy.json
OJT_POSTGRES_DB=ojtflow
OJT_POSTGRES_USER=ojtflow
OJT_POSTGRES_PASSWORD=ojtflow
OJT_POSTGRES_PORT=15432
OJT_REDIS_PORT=16379
OJT_RABBITMQ_AMQP_PORT=15673
OJT_RABBITMQ_MANAGEMENT_PORT=15672
OJT_RABBITMQ_USER=ojtflow
OJT_RABBITMQ_PASSWORD=ojtflow
OJT_API_PORT=18000
OJT_FRONTEND_PORT=15173
OJT_KEYCLOAK_PORT=18080
OJT_FLOWER_PORT=15555
OJT_FLOWER_UNAUTHENTICATED_API=true
OJT_PROMETHEUS_PORT=19090
OJT_GRAFANA_PORT=13000
OJT_LOKI_PORT=13100
VITE_API_BASE_URL=/api/v1
# Use parsing,embeddings-local,rag-framework when building Docker image with
# local HF models/rerankers and the optional LlamaIndex retrieval adapter.
OJT_PYTHON_EXTRAS=parsing,graph
# Auth provider values: keycloak or google. The compose stack defaults to
# Keycloak, which hosts local email/password users and can broker Google.
OJT_AUTH_PROVIDER=keycloak
OJT_KEYCLOAK_ADMIN_USERNAME=admin
OJT_KEYCLOAK_ADMIN_PASSWORD=admin
# Browser-facing Keycloak URL (where the user is redirected to log in).
OJT_KEYCLOAK_BASE_URL=http://localhost:18080
# Internal URL the API container uses to reach Keycloak over the docker network.
OJT_DOCKER_KEYCLOAK_BASE_URL=http://keycloak:8080
OJT_KEYCLOAK_REALM=ojtflow
OJT_KEYCLOAK_CLIENT_ID=ojtflow-api
OJT_KEYCLOAK_CLIENT_SECRET=ojtflow-local-secret
OJT_KEYCLOAK_REDIRECT_URI=http://localhost:15173/auth/callback
OJT_KEYCLOAK_OAUTH_TIMEOUT_SECONDS=10.0
OJT_FRONTEND_BASE_URL=http://localhost:15173
OJT_INVITATION_TTL_SECONDS=604800
OJT_GOOGLE_CLIENT_ID=
OJT_GOOGLE_CLIENT_SECRET=
OJT_GOOGLE_REDIRECT_URI=http://localhost:18000/api/v1/auth/google/callback
OJT_GOOGLE_FRONTEND_REDIRECT_URI=http://localhost:15173/auth/callback
# Extra OAuth redirect URIs must be HTTPS unless they are localhost/127.0.0.1/[::1].
OJT_ALLOWED_AUTH_REDIRECT_URIS=
# Workspace and cookie domains must be bare DNS domains, not URLs, ports, or wildcards.
OJT_ALLOWED_GOOGLE_HOSTED_DOMAINS=
# Numeric timeout, TTL, byte-limit, and chunk-size values must be positive.
OJT_GOOGLE_OAUTH_TIMEOUT_SECONDS=10.0
OJT_AUTH_SESSION_TTL_SECONDS=604800
OJT_AUTH_STATE_TTL_SECONDS=600
OJT_AUTH_COOKIE_NAME=ojtflow_session
OJT_AUTH_COOKIE_SECURE=false
OJT_AUTH_COOKIE_SAMESITE=lax
# Leave blank for localhost/dev. Set a bare DNS domain such as .example.com in production.
OJT_AUTH_COOKIE_DOMAIN=
OJT_MAX_UPLOAD_BYTES=26214400
OJT_MAX_INLINE_DATA_BYTES=1048576
OJT_UPLOAD_READ_CHUNK_BYTES=1048576
# Supported upload extensions only; unsafe values such as .exe are rejected.
OJT_ALLOWED_UPLOAD_EXTENSIONS=.pdf,.docx,.xlsx,.xls,.pptx,.png,.jpg,.jpeg,.tiff,.tif,.bmp,.gif,.webp,.html,.htm,.md,.txt,.csv,.json,.yaml,.yml
# Queue-backed execution for long-running OCR/RAG jobs. Pilot/production
# require rabbitmq; local standalone API may use sync_local.
OJT_QUEUE_BACKEND=rabbitmq
OJT_RABBITMQ_URL=amqp://ojtflow:ojtflow@localhost:15673//
OJT_CELERY_TASK_TIME_LIMIT_SECONDS=900
OJT_CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=840
OJT_OCR_QUEUE=ocr
OJT_RAG_QUEUE=rag
OJT_EMBEDDING_QUEUE=embedding
OJT_MEDSIGLIP_QUEUE=medsiglip
OJT_INGESTION_QUEUE=ingestion
OJT_EXPORT_QUEUE=export
OJT_DEFAULT_QUEUE=default
OJT_OCR_WORKER_CONCURRENCY=2
OJT_RAG_WORKER_CONCURRENCY=2
OJT_EMBEDDING_WORKER_CONCURRENCY=1
OJT_MEDSIGLIP_WORKER_CONCURRENCY=1
OJT_INGESTION_WORKER_CONCURRENCY=2
OJT_EXPORT_WORKER_CONCURRENCY=1
OJT_SENTRY_DSN=
OJT_LOKI_ENABLED=true
# Production RAG embeddings. Real semantic providers are required; fake/hash
# providers are rejected and missing provider config fails startup/readiness.
OJT_EMBEDDING_PROVIDER=openai
OJT_EMBEDDING_MODEL=text-embedding-3-small
OJT_EMBEDDING_DIMENSIONS=384
OJT_OPENAI_API_KEY=
# Local GPU semantic retrieval option:
# OJT_EMBEDDING_PROVIDER=huggingface
# OJT_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# OJT_EMBEDDING_DIMENSIONS=384
# OJT_HF_EMBEDDING_DEVICE=cuda
OJT_OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1
OJT_OPENAI_EMBEDDING_TIMEOUT_SECONDS=20.0
# Natural-language assistant. Production must set a real provider and key.
OJT_LLM_PROVIDER=openai
OJT_LLM_MODEL=chat-latest
OJT_LLM_PLANNING_MODEL=chat-latest
OJT_LLM_SYNTHESIS_MODEL=chat-latest
OJT_LLM_VISION_MODEL=gpt-4.1-mini
OJT_LLM_BASE_URL=https://api.openai.com/v1
OJT_LLM_TIMEOUT_SECONDS=90.0
OJT_LLM_MAX_TOOL_CALLS=4
OJT_LLM_PLANNING_PROGRESS_INTERVAL_SECONDS=2.0
OJT_REAL_SMOKE_API_BASE_URL=http://127.0.0.1:18000
OJT_REAL_SMOKE_AUTH_TOKEN=
OJT_REAL_SMOKE_TIMEOUT_SECONDS=60
# External provider policy. PHI is blocked from OpenAI-compatible providers
# unless an administrator explicitly allows it for the relevant surface.
OJT_EXTERNAL_OPENAI_LLM_ENABLED=true
OJT_EXTERNAL_OPENAI_LLM_ALLOW_PHI=false
OJT_EXTERNAL_OPENAI_OCR_ENABLED=true
OJT_EXTERNAL_OPENAI_OCR_ALLOW_PHI=false
OJT_EXTERNAL_OPENAI_OCR_ALLOW_UNKNOWN=true
OJT_EXTERNAL_OPENAI_EMBEDDINGS_ENABLED=true
OJT_EXTERNAL_OPENAI_EMBEDDINGS_ALLOW_PHI=false
OJT_EXTERNAL_MEDICAL_SEARCH_ENABLED=true
OJT_EXTERNAL_MEDICAL_SEARCH_ALLOW_PHI=false
# Enables MarkItDown OCR plugin for scanned PDFs and image-heavy Office files
# when an OpenAI-compatible key is configured.
OJT_MARKITDOWN_OCR_ENABLED=true
# Legacy alias: OJT_OPENAI_VISION_MODEL is still accepted, but new configs
# should use OJT_LLM_VISION_MODEL.
# OJT_OPENAI_VISION_MODEL=gpt-4.1-mini
OJT_HF_EMBEDDING_DEVICE=auto
OJT_HF_EMBEDDING_BATCH_SIZE=32
OJT_HF_EMBEDDING_CACHE_DIR=var/huggingface
# Optional second-stage CrossEncoder reranking for top retrieval candidates.
OJT_RERANK_PROVIDER=none
# OJT_RERANK_PROVIDER=huggingface
OJT_RERANK_MODEL=BAAI/bge-reranker-base
OJT_RERANK_DEVICE=auto
OJT_RERANK_BATCH_SIZE=16
OJT_RERANK_CANDIDATE_LIMIT=20
OJT_RERANK_SCORE_WEIGHT=0.08
OJT_RETRIEVAL_CORPUS_DIRS=knowledge/corpus
OJT_RETRIEVAL_CHUNK_MAX_CHARS=1200
OJT_RETRIEVAL_CHUNK_OVERLAP_CHARS=160
OJT_RETRIEVAL_DIVERSITY_ENABLED=true
OJT_RETRIEVAL_DIVERSITY_LAMBDA=0.72
# Postgres pgvector HNSW recall/speed tradeoff. Higher improves recall and costs latency.
OJT_RETRIEVAL_HNSW_EF_SEARCH=100
# Production RAG retrieval is vector-only over pgvector. Lexical/BM25 fallback is forbidden.
OJT_RETRIEVAL_MODE=semantic_vector
# Supported values: custom, llamaindex. Production requires custom Postgres pgvector retrieval.
OJT_RETRIEVAL_FRAMEWORK=custom
OJT_RETRIEVAL_CANDIDATE_MULTIPLIER=4
OJT_RETRIEVAL_MIN_CANDIDATES=12
OJT_RETRIEVAL_VECTOR_WEIGHT=0.62
OJT_RETRIEVAL_BM25_WEIGHT=0.38
# Persistent corpus knowledge graph (docs/corpus_knowledge_graph_v0.md).
# Backend values: neo4j (default), memory (in-process tests only), kuzu (embedded).
# The neo4j/kuzu drivers ship in the optional 'graph' extra. The compose default
# points at graph-med's Neo4j container published on host Bolt port 7688.
OJT_KNOWLEDGE_GRAPH_BACKEND=neo4j
OJT_NEO4J_URI=bolt://host.docker.internal:7688
OJT_NEO4J_USER=neo4j
# Dev graph-med default; change in any shared/production deployment.
OJT_NEO4J_PASSWORD=testpassword123
OJT_NEO4J_DATABASE=neo4j
# graph-med patient annotation requires the imported ontology and ICD vector index.
# NER/NED uses the normal app LLM/embedding provider by default. Optional graph-med
# local compute such as GNN/NER uses the graph-med-service GPU runtime, not vLLM.
OJT_GRAPH_MED_ANNOTATION_ENABLED=true
OJT_GRAPH_MED_SERVICE_BASE_URL=http://graph-med-service:8010
OJT_GRAPH_MED_SERVICE_PORT=18102
OJT_GRAPH_MED_EMBEDDING_BASE_URL=
OJT_GRAPH_MED_LLM_BASE_URL=
OJT_GRAPH_MED_LLM_MODEL=
OJT_GRAPH_MED_EMBEDDING_MODEL=
OJT_GRAPH_MED_GNN_BASE_URL=
OJT_GRAPH_MED_GPU=all
OJT_GRAPH_MED_DEVICE=cuda
OJT_GRAPH_MED_REQUIRE_GPU=true
OJT_HF_CACHE_DIR=/home/vund/.cache/huggingface
OJT_GRAPH_MED_ICD_VECTOR_INDEX=icd_disease_embedding
OJT_GRAPH_MED_CANDIDATE_K=10
OJT_GRAPH_MED_TIMEOUT_SECONDS=90.0
# MedSigLIP image-text classification service. Accept the model terms on
# Hugging Face first, then provide HF_TOKEN/HUGGING_FACE_HUB_TOKEN for the
# medsiglip profile.
OJT_MEDSIGLIP_ENABLED=true
OJT_MEDSIGLIP_BASE_URL=http://localhost:18103
OJT_MEDSIGLIP_DOCKER_BASE_URL=http://medsiglip:8000
OJT_MEDSIGLIP_MODEL=google/medsiglip-448
OJT_MEDSIGLIP_PORT=18103
OJT_MEDSIGLIP_GPU=0
OJT_MEDSIGLIP_DEVICE=cuda
OJT_MEDSIGLIP_REQUIRE_GPU=true
OJT_MEDSIGLIP_PRELOAD=true
OJT_MEDSIGLIP_TIMEOUT_SECONDS=90.0
OJT_DCGM_EXPORTER_PORT=19400
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=
# Embedded-graph alternative; used only when OJT_KNOWLEDGE_GRAPH_BACKEND=kuzu.
OJT_KUZU_DB_PATH=var/kuzu/corpus
