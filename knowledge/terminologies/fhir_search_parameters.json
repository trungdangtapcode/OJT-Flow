{
  "version": "FHIR R4 curated seed v0",
  "source": "https://hl7.org/fhir/R4/search.html",
  "purpose": "FHIR search parameter seed for rule-based medical retrieval hints. This is not a complete FHIR CapabilityStatement.",
  "resources": [
    {
      "resource_type": "Observation",
      "clinical_domain": "laboratory",
      "parameters": [
        {
          "name": "code",
          "type": "token",
          "target_field": "Observation.code",
          "example": "Observation?code=http://loinc.org|2345-7",
          "standard_systems": ["FHIR", "LOINC"]
        },
        {
          "name": "subject",
          "type": "reference",
          "target_field": "Observation.subject",
          "example": "Observation?subject=Patient/<id>",
          "standard_systems": ["FHIR"]
        },
        {
          "name": "patient",
          "type": "reference",
          "target_field": "Observation.subject where subject is Patient",
          "example": "Observation?patient=<patient-id>",
          "standard_systems": ["FHIR"]
        },
        {
          "name": "date",
          "type": "date",
          "target_field": "Observation.effective[x]",
          "example": "Observation?date=ge2026-01-01",
          "standard_systems": ["FHIR"]
        },
        {
          "name": "value-quantity",
          "type": "quantity",
          "target_field": "Observation.valueQuantity",
          "example": "Observation?value-quantity=gt5|http://unitsofmeasure.org|mmol/L",
          "standard_systems": ["FHIR", "UCUM"]
        },
        {
          "name": "combo-code",
          "type": "token",
          "target_field": "Observation.code or Observation.component.code",
          "example": "Observation?combo-code=http://loinc.org|4548-4",
          "standard_systems": ["FHIR", "LOINC"]
        }
      ]
    },
