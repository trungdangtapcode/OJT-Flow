{
  "version": "retrieval_filter_suggestion_rules.v1",
  "rules": [
    {
      "rule_id": "suggest_laboratory_domain",
      "field": "clinical_domain",
      "value": "laboratory",
      "reason": "Detected laboratory observation context.",
      "confidence": 0.92,
      "match": {
        "any_concepts": [
          "laboratory_observation_identity",
          "hba1c_laboratory_test",
          "unit_normalization",
          "fhir_observation_profile"
        ],
        "any_standards": ["FHIR", "LOINC", "UCUM"],
        "any_candidate_domains": ["laboratory"]
      }
    },
    {
      "rule_id": "suggest_medication_domain",
      "field": "clinical_domain",
      "value": "medication",
      "reason": "Detected medication controlled-vocabulary context.",
      "confidence": 0.82,
      "match": {
        "any_concepts": [
          "medication_normalization",
          "regulatory_drug_safety_search"
        ],
        "any_candidate_domains": ["medication"],
        "any_standards": ["RxNorm", "openFDA"]
      }
    },
    {
      "rule_id": "suggest_literature_domain",
      "field": "clinical_domain",
      "value": "literature",
      "reason": "Detected biomedical literature or trial-search context.",
      "confidence": 0.82,
      "match": {
        "any_concepts": [
          "biomedical_literature_search",
          "clinical_trial_search"
        ],
        "any_candidate_domains": ["literature"],
        "any_standards": ["MeSH", "ClinicalTrials.gov"]
      }
    },
    {
      "rule_id": "suggest_analytics_domain",
      "field": "clinical_domain",
      "value": "analytics",
      "reason": "Detected observational analytics export context.",
