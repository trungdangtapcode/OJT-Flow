#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

if [[ -f .env ]]; then
  set -a
  # shellcheck disable=SC1091
  source .env
  set +a
fi

export PYTHONPATH="${PYTHONPATH:-src}"

exec "${PYTHON:-./.venv/bin/python}" -m uvicorn ojtflow.interfaces.api.app:app \
  --host "${OJT_API_HOST:-127.0.0.1}" \
  --port "${OJT_API_PORT:-18000}" \
  "$@"
